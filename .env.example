# Shopify Store - yeni sistem (Dev Dashboard Custom App)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Client credentials - Dev Dashboard > Apps > Settings'den alın
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=your_client_secret

# NOT: Artık SHOPIFY_ACCESS_TOKEN gerekmez.
# Token CLIENT_ID + CLIENT_SECRET ile otomatik alınır (24 saatlik, otomatik yenilenir).
